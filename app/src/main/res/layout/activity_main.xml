<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NeoTuner"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/noteNameTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--"
        android:textSize="120sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/frequencyTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="-- Hz"
        android:textSize="28sp"
        android:textColor="#00FF88"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/targetFrequencyTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="目标: -- Hz"
        android:textSize="18sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/centsTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0.0 音分"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <com.neotuner.app.OscilloscopeView
        android:id="@+id/oscilloscopeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="钢琴88键全音域支持"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingTop="16dp" />

</LinearLayout>
